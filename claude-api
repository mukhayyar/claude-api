#!/usr/bin/env bash
# Run Claude Code against a non-subscription API model (MiMo, etc.) in tmux,
# fully isolated from your default ~/.claude subscription setup.
# For Windows, see claude-api.ps1 (PowerShell + psmux).
#
#   claude-api                 -> lists profiles
#   claude-api mimo            -> attach/create tmux session for the 'mimo' profile
#   claude-api mimo --main     -> use ~/.claude config (resume default session with -r)
#   claude-api mimo -- -p      -> args after `--` are passed straight to `claude`
#   claude-api create-profile  -> interactively create a new profile
#
# Add a model: drop ~/.claude-api/profiles/<name>.env (copy an .example).
#
# Prereqs (claude, tmux) are auto-installed if missing. Set CLAUDE_API_ASSUME_YES=1
# to skip the install prompt. `claude-api doctor` just runs the prereq check.
set -euo pipefail

ROOT="$HOME/.claude-api"
MAIN_SETTINGS="$HOME/.claude/settings.json"

print_banner() {
  cat <<'BANNER'
   _____ _                 _         _      _____ _   _ _____
  /  __ \ |               | |       | |    |_   _| \ | |  __ \
  | /  \/ | __ _ _ __ ___ | |    ___| |_     | | |  \| | |  \/
  | |   | |/ _` | '_ ` _ \| |   / _ \ __|    | | | . ` | | __
  | \__/\ | (_| | | | | | | |__|  __/ |_    _| |_| |\  | |_\ \
   \____/_|\__,_|_| |_| |_|_____\___|\__|   \___/\_| \__/____/

BANNER
  echo "  Claude Code, any API. Stay in Claude no matter which model you use."
  echo
}

print_help() {
  print_banner
  cat <<EOF
USAGE
  claude-api <profile> [--main] [-- <claude args>]
  claude-api create-profile
  claude-api doctor
  claude-api --help | -h

COMMANDS
  <profile>        Launch a profile in an isolated tmux session.
  create-profile   Interactively create a new ~/.claude-api/profiles/*.env file.
  doctor           Check that claude and tmux are installed.
  --help, -h       Show this help message.

FLAGS
  --main           Use your default ~/.claude config dir instead of an isolated
                   one. This lets <profile> use the profile's API while letting
                   <claude args> like -r resume your main subscription sessions.
  --               Everything after -- is passed straight to claude.

EXAMPLES
  claude-api deepseek
  claude-api kimi -- -p "hi"
  claude-api kimi --main -- -r
  claude-api create-profile

ENVIRONMENT
  CLAUDE_API_ASSUME_YES=1  Skip install confirmations for tmux/claude.
  CLAUDE_API_SAFE=1        Keep normal permission prompts in isolated profiles.

PROFILES
  Real profiles live in ~/.claude-api/profiles/*.env and are gitignored.
  Example templates are in ~/.claude-api/profiles/*.env.example.

WINDOWS
  Use claude-api.ps1 with PowerShell 7+ and psmux.
EOF
}

# --- prereq scan + cross-distro install ------------------------------------
pm_install() { # $* = packages; picks whatever package manager exists
  local sudo=""; [[ $EUID -ne 0 ]] && command -v sudo >/dev/null && sudo="sudo"
  if   command -v brew    >/dev/null; then brew install "$@"
  elif command -v apt-get >/dev/null; then $sudo apt-get update -qq && $sudo apt-get install -y "$@"
  elif command -v dnf     >/dev/null; then $sudo dnf install -y "$@"
  elif command -v yum     >/dev/null; then $sudo yum install -y "$@"
  elif command -v pacman  >/dev/null; then $sudo pacman -Sy --noconfirm "$@"
  elif command -v zypper  >/dev/null; then $sudo zypper install -y "$@"
  elif command -v apk     >/dev/null; then $sudo apk add "$@"
  elif command -v pkg     >/dev/null; then $sudo pkg install -y "$@"   # *BSD / Termux
  else return 1; fi
}

confirm() { # $1 = prompt; honours CLAUDE_API_ASSUME_YES
  [[ "${CLAUDE_API_ASSUME_YES:-}" == 1 ]] && return 0
  local a
  read -r -p "$1 [Y/n] " a || return 1
  [[ -z "$a" || "$a" =~ ^[Yy] ]]
}

prompt() { # $1 = prompt text, $2 = default value
  local input
  if [[ -n "${2:-}" ]]; then
    read -r -p "$1 [$2]: " input || return 1
    echo "${input:-$2}"
  else
    read -r -p "$1: " input || return 1
    echo "$input"
  fi
}

prompt_secret() { # $1 = prompt text
  local input
  read -r -sp "$1: " input || return 1
  echo >&2
  echo "$input"
}

ensure_deps() {
  case "$(uname -s)" in
    MINGW*|MSYS*|CYGWIN*) echo "Native Windows has no tmux — run this under WSL or Git Bash." >&2; exit 1;;
  esac
  if ! command -v tmux >/dev/null; then
    confirm "tmux not found. Install it?" || { echo "tmux required."; exit 1; }
    pm_install tmux || { echo "No supported package manager — install tmux manually." >&2; exit 1; }
  fi
  if ! command -v claude >/dev/null; then
    confirm "Claude Code not found. Install it?" || { echo "claude required."; exit 1; }
    curl -fsSL https://claude.ai/install.sh | bash
    command -v claude >/dev/null || export PATH="$HOME/.local/bin:$PATH"
  fi
  command -v claude tmux >/dev/null || { echo "Prereqs still missing after install." >&2; exit 1; }
}

plugin_dirs() {
  # Pass the latest installed version of each plugin from the global cache so
  # claude-mem (and other enabled plugins) keep working in isolated profiles.
  local dir latest
  for dir in "$HOME/.claude/plugins/cache"/*/*; do
    [[ -d "$dir" ]] || continue
    latest=$(ls -d "$dir"/* 2>/dev/null | sort -V | tail -1)
    [[ -d "$latest" ]] || continue
    printf '%s' " --plugin-dir $(printf '%q' "$latest")"
  done
}

proxy_running() {
  local port="${1:-}"
  [[ -z "$port" ]] && return 1
  # /dev/tcp works in bash; nc is a fallback.
  if command -v nc >/dev/null; then
    nc -z localhost "$port" 2>/dev/null
  else
    (exec 3<>/dev/tcp/localhost/"$port") 2>/dev/null
  fi
}

start_proxy() {
  local port="${LLAMA_PROXY_PORT:-}"
  [[ -z "$port" ]] && return 0
  proxy_running "$port" && return 0

  echo "starting llama proxy on port $port ..." >&2
  nohup node "$ROOT/proxy/proxy.js" \
    >> "$ROOT/proxy/$PROFILE.log" 2>&1 &
  local pid=$!

  # Wait up to 5s for the proxy to accept connections.
  for _ in $(seq 1 50); do
    sleep 0.1
    proxy_running "$port" && return 0
  done

  echo "proxy failed to start (pid $pid). logs:" >&2
  tail -n 20 "$ROOT/proxy/$PROFILE.log" 2>/dev/null || true
  return 1
}

session_name() {
  # Include a hash of the full working directory so each folder gets its own
  # claude-api tmux session for the same profile.
  local suffix=""
  [[ "${USE_MAIN:-0}" == 1 ]] && suffix="-main"
  local base
  base=$(basename "$PWD")
  local hash
  hash=$(printf '%s' "$PWD" | cksum | awk '{print $1}')
  printf 'capi-%s%s-%s-%s' "$PROFILE" "$suffix" "$base" "$hash"
}

create_profile() {
  print_banner
  echo "Create a new claude-api profile"
  echo

  local name provider base_url model auth_token profile_path

  while true; do
    name=$(prompt "Profile name (e.g. deepseek, kimi, my-mimo)")
    [[ -n "$name" ]] && break
    echo "Profile name is required."
  done

  profile_path="$ROOT/profiles/$name.env"
  if [[ -f "$profile_path" ]]; then
    confirm "Profile '$name' already exists. Overwrite?" || { echo "Aborted."; exit 0; }
  fi

  echo
  echo "Choose a provider template:"
  echo "  1) DeepSeek"
  echo "  2) Moonshot Kimi"
  echo "  3) Xiaomi MiMo"
  echo "  4) Local llama.cpp (via proxy)"
  echo "  5) Custom"
  local choice
  choice=$(prompt "Provider" "5")

  case "$choice" in
    1|deepseek|DeepSeek)
      base_url="https://api.deepseek.com/anthropic"
      model="deepseek-v4-pro[1m]"
      ;;
    2|kimi|Kimi|moonshot)
      base_url="https://api.moonshot.ai/anthropic"
      model="kimi-k2.7-code"
      ;;
    3|mimo|MiMo|xiaomi)
      base_url="https://api.example-mimo.com"
      model="mimo-v2.5-pro[1m]"
      ;;
    4|llama|local)
      base_url="http://localhost:4000"
      model="claude-sonnet-4-6"
      ;;
    *)
      base_url=$(prompt "Anthropic-compatible base URL")
      model=$(prompt "Model name")
      ;;
  esac

  if [[ "$choice" == "4" || "$choice" == "llama" || "$choice" == "local" ]]; then
    auth_token="no-key"
  else
    auth_token=$(prompt_secret "API key")
  fi

  mkdir -p "$ROOT/profiles"
  cat > "$profile_path" <<EOF
# claude-api profile: $name
ANTHROPIC_AUTH_TOKEN=$auth_token
ANTHROPIC_BASE_URL=$base_url
ANTHROPIC_MODEL=$model
ANTHROPIC_DEFAULT_SONNET_MODEL=$model
ANTHROPIC_DEFAULT_OPUS_MODEL=$model
ANTHROPIC_DEFAULT_HAIKU_MODEL=$model
CLAUDE_CODE_SUBAGENT_MODEL=$model
EOF

  if [[ "$choice" == "4" || "$choice" == "llama" || "$choice" == "local" ]]; then
    cat >> "$profile_path" <<EOF

# Proxy configuration
LLAMA_PROXY_PORT=4000
LLAMA_OPENAI_BASE_URL=http://localhost:8081/v1
LLAMA_OPENAI_MODEL=Qwen3.5-0.8B-Q5_K_M
LLAMA_OPENAI_API_KEY=no-key
EOF
  fi

  chmod 600 "$profile_path"
  echo
  echo "Created profile: $profile_path"
  echo "Launch it with: claude-api $name"
}

PROFILE="${1:-}"

if [[ -z "$PROFILE" || "$PROFILE" == "--help" || "$PROFILE" == "-h" ]]; then
  print_help
  exit 0
fi

if [[ "$PROFILE" == "doctor" ]]; then ensure_deps; echo "ok: claude + tmux present."; exit 0; fi

if [[ "$PROFILE" == "create-profile" ]]; then
  create_profile
  exit 0
fi

if [[ -z "$PROFILE" ]]; then
  print_banner
  echo "profiles:"; ls "$ROOT/profiles"/*.env 2>/dev/null | sed 's#.*/##;s#\.env$#  #' || echo "  (none)"
  echo "usage: claude-api <profile> [--main] [-- <claude args>]"
  exit 0
fi

ENV_FILE="$ROOT/profiles/$PROFILE.env"
[[ -f "$ENV_FILE" ]] || { echo "no such profile: $PROFILE ($ENV_FILE)"; exit 1; }

ensure_deps

shift || true

# --main: use the default ~/.claude config dir so `-r` resumes the main session.
USE_MAIN=0
if [[ "${1:-}" == "--main" ]]; then
  USE_MAIN=1
  shift || true
fi

[[ "${1:-}" == "--" ]] && shift || true   # drop the -- separator if present

if [[ "$USE_MAIN" == 1 ]]; then
  # Use main Claude config; still apply the profile's API env vars.
  CFG="$HOME/.claude"
  mkdir -p "$CFG"
else
  # Isolated config dir => separate settings/history/auth, subscription untouched.
  CFG="$ROOT/configs/$PROFILE"
  mkdir -p "$CFG"
  [[ -f "$CFG/.claude.json" ]] || echo '{"hasCompletedOnboarding":true}' > "$CFG/.claude.json"
fi

# Seed isolated settings from the main Claude config so plugins (claude-mem, etc.) keep working.
if [[ "$USE_MAIN" != 1 && ! -f "$CFG/settings.json" ]]; then
  if [[ -f "$MAIN_SETTINGS" ]]; then
    cp "$MAIN_SETTINGS" "$CFG/settings.json"
  else
    cat > "$CFG/settings.json" <<'JSON'
{
  "includeCoAuthoredBy": false,
  "attribution": { "commit": "empty", "pr": "empty" }
}
JSON
  fi
fi

# Load profile env so we can start the proxy with the right variables.
set -a
# shellcheck source=/dev/null
. "$ENV_FILE"
set +a

# Auto-start the local llama proxy if this profile defines one.
start_proxy

# Isolated throwaway config => skip permission prompts by default.
# --main uses the real ~/.claude config, so keep the normal permission flow.
# Set CLAUDE_API_SAFE=1 to keep the normal permission flow everywhere.
SKIP="--dangerously-skip-permissions"
if [[ "${USE_MAIN:-0}" == 1 || "${CLAUDE_API_SAFE:-}" == 1 ]]; then
  SKIP=""
fi

PLUGIN_FLAGS=$(plugin_dirs)
SESSION=$(session_name)
if ! tmux has-session -t "$SESSION" 2>/dev/null; then
  # set -a exports everything sourced from the profile file
  # -c "$PWD" keeps the session in the folder where claude-api was invoked.
  # shellcheck disable=SC2086
  tmux new-session -d -s "$SESSION" -c "$PWD" -e CLAUDE_CONFIG_DIR="$CFG" \
    "set -a; . '$ENV_FILE'; set +a; exec claude $SKIP $PLUGIN_FLAGS $*"
fi
exec tmux attach -t "$SESSION"
