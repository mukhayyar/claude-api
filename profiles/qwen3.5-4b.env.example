# Local Qwen3.5 4B via llama.cpp llama-server + Anthropic-compatible proxy
ANTHROPIC_AUTH_TOKEN=no-key
ANTHROPIC_BASE_URL=http://localhost:4002
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_DEFAULT_SONNET_MODEL=claude-sonnet-4-6
ANTHROPIC_DEFAULT_OPUS_MODEL=claude-sonnet-4-6
ANTHROPIC_DEFAULT_HAIKU_MODEL=claude-sonnet-4-6
CLAUDE_CODE_SUBAGENT_MODEL=claude-sonnet-4-6

# Proxy configuration
LLAMA_PROXY_PORT=4002
LLAMA_OPENAI_BASE_URL=http://localhost:8081/v1
LLAMA_OPENAI_MODEL=Qwen3.5-4B-Q4_K_M
LLAMA_OPENAI_API_KEY=no-key
